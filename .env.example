# Contact Form Email Configuration
# Choose ONE of the email services below

# Option 1: Gmail SMTP (Direct Gmail integration)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password

# Option 2: SendGrid (Recommended for production)
SENDGRID_API_KEY=SG.your-sendgrid-api-key

# Email Settings (Required)
EMAIL_TO=contact@beyondtheclassroom.in
EMAIL_FROM=noreply@yourdomain.com

# Environment
NODE_ENV=production

# API Configuration
VITE_API_URL=/api/contact

# Newsletter (Substack) — optional; used on the home page newsletter section
# Embed URL often looks like: https://yourpublication.substack.com/embed
VITE_SUBSTACK_EMBED_URL=
# Public publication URL: https://yourpublication.substack.com
VITE_SUBSTACK_PROFILE_URL=

# Case studies API endpoint (optional override)
VITE_CASE_STUDIES_API_URL=/api/case-studies

# Google Drive case studies folder (used by /api/case-studies serverless function)
CASE_STUDIES_DRIVE_FOLDER_ID=
# OAuth credentials (recommended for personal Gmail accounts)

# Service account credentials (optional alternative)

# Google Drive Integration
VITE_GOOGLE_DRIVE_API_KEY=your-google-drive-api-key
VITE_GOOGLE_DRIVE_PROJECTS_FOLDER=
VITE_GOOGLE_DRIVE_NEWSLETTER_FOLDER=your-newsletter-folder-id
VITE_GOOGLE_DRIVE_PROGRAMS_FOLDER=your-programs-folder-id
VITE_GOOGLE_DRIVE_TEAM_FOLDER=your-team-folder-id